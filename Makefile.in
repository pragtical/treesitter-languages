STRIP ?= strip
STRIPFLAGS ?= --strip-unneeded
CFLAGS ?= -Os
CFLAGS += -fPIC -std=$CSTD
SOEXT ?= .so

INCS := -I$INC_PATH
SRCS := $SRCS
OBJS := $$(SRCS:.c=.o)
SOFILE := parser$$(SOEXT)

all: _all
_all: $$(SOFILE)

$$(SOFILE): $$(OBJS)
	$$(CC) -shared -o $$@ $$^ $$(LDFLAGS)
	@if [ -n "$$(STRIP)" ]; then $$(STRIP) $$(STRIPFLAGS) "$$@"; fi

%.o: %.c
	$$(CC) -c -o $$@ $$< $$(CFLAGS) $$(INCS)

clean:
	$$(RM) $$(OBJS) $$(SOFILE)

.PHONY: all _all clean
