-- mod-version: $MODVERSION

local treesitter_languages = require 'plugins.treesitter.languages'

local pkg_name = ...
local path = pkg_name:gsub('%.', '/')

treesitter_languages.addDef {
	name = '$NAME',
	files = { $PATTERNS },
	path = USERDIR .. '/' .. path,
	soFile = $SOFILE_NAME,
	queryFiles = {
$QUERY_FILES
	},
}
